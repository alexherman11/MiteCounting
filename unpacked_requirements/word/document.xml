        </w:numPr>
      </w:pPr>
      <w:r>
        <w:t>Please attempt to cite the images (if possible).</w:t>
      </w:r>
      
      
    </w:p>
    <w:p w14:paraId="62DC7EC8" w14:textId="0B5C1F05" w:rsidR="00512C8B" w:rsidRDefault="00512C8B" w:rsidP="00512C8B">
